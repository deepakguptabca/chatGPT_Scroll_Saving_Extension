{
  "manifest_version": 3,
  "name": "ChatGPT Scroll Navigator",
  "version": "1.0",
  "description": "Right sidebar navigator for ChatGPT messages",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}